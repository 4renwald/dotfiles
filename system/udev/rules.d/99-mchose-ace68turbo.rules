# MCHOSE Ace 68 Turbo 16K (3837:3026)
ACTION=="add", SUBSYSTEM=="usb", ATTR{idVendor}=="3837", ATTR{idProduct}=="3026", TEST=="bConfigurationValue", ATTR{bConfigurationValue}="1"

# Create a stable symlink so you can always refer to /dev/ace68turbo-hidraw
ACTION=="add", SUBSYSTEM=="hidraw", ATTRS{idVendor}=="3837", ATTRS{idProduct}=="3026", MODE:="0666", SYMLINK+="ace68turbo-hidraw"
